<Window x:Class="CybersecurityChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ Cybersecurity Awareness Chatbot" 
        Height="750" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        ResizeMode="CanResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ASCII Art Banner -->
        <Border Grid.Row="0" Background="#16213E" CornerRadius="10" Margin="5" Padding="10" BorderBrush="#0F3460" BorderThickness="1">
            <TextBlock x:Name="AsciiArt" 
                       FontFamily="Consolas" 
                       FontSize="9" 
                       Foreground="#00FFAA"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- User Info Panel -->
        <Border Grid.Row="1" Background="#16213E" CornerRadius="10" Margin="5" Padding="10" BorderBrush="#0F3460" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="👤 Your Name: " Foreground="#E94560" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox x:Name="txtUserName" Width="180" Height="30" Margin="10,0" Background="#0F3460" Foreground="#FFFFFF" BorderBrush="#00FFAA" BorderThickness="1" FontSize="13"/>
                <Button x:Name="btnSaveName" Content="💾 Save" Width="80" Height="30" Background="#00FFAA" Foreground="#1A1A2E" FontWeight="Bold" Click="BtnSaveName_Click"/>
                <TextBlock x:Name="lblMemory" Text="💡 I'll remember you!" Foreground="#8888FF" FontSize="12" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Sentiment & Memory Status -->
        <Border Grid.Row="2" Background="#16213E" CornerRadius="10" Margin="5,0,5,5" Padding="5" BorderBrush="#0F3460" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="lblSentiment" Text="😊 Sentiment: Neutral" Foreground="#FFAA00" FontSize="12"/>
                <TextBlock x:Name="lblMemoryStatus" Text="" Foreground="#00FFAA" FontSize="12" Margin="20,0,0,0"/>
                <TextBlock x:Name="lblTopic" Text="" Foreground="#E94560" FontSize="12" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Voice Control Panel -->
        <Border Grid.Row="3" Background="#16213E" CornerRadius="10" Margin="5" Padding="5" BorderBrush="#0F3460" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🔊 Voice: " Foreground="#FFFFFF" FontSize="12" VerticalAlignment="Center"/>
                <ToggleButton x:Name="btnVoiceOnOff" 
                              Content="🔊 ON" 
                              Width="70" 
                              Height="25"
                              Background="#00FFAA"
                              Foreground="#1A1A2E"
                              FontWeight="Bold"
                              FontSize="11"
                              IsChecked="True"
                              Checked="BtnVoiceOnOff_Checked"
                              Unchecked="BtnVoiceOnOff_Unchecked"/>
                <TextBlock Text=" | " Foreground="#888888" FontSize="12" Margin="10,0"/>
                <Button x:Name="btnStopVoice" 
                        Content="⏹️ Stop Speaking" 
                        Width="110" 
                        Height="25"
                        Background="#E94560"
                        Foreground="#FFFFFF"
                        FontWeight="Bold"
                        FontSize="11"
                        Click="BtnStopVoice_Click"/>
                <TextBlock Text=" | " Foreground="#888888" FontSize="12" Margin="10,0"/>
                <Button x:Name="btnExitChat" 
                        Content="🚪 Exit Chatbot" 
                        Width="110" 
                        Height="25"
                        Background="#FF4444"
                        Foreground="#FFFFFF"
                        FontWeight="Bold"
                        FontSize="11"
                        Click="BtnExitChat_Click"/>
            </StackPanel>
        </Border>

        <!-- Chat Display Area -->
        <Border Grid.Row="4" Background="#16213E" CornerRadius="10" Margin="5" Padding="10" BorderBrush="#0F3460" BorderThickness="1">
            <ScrollViewer x:Name="scrollViewer" VerticalScrollBarVisibility="Auto">
                <RichTextBox x:Name="rtbChatDisplay" 
                             IsReadOnly="True" 
                             Background="#16213E"
                             Foreground="#FFFFFF"
                             BorderBrush="Transparent"
                             FontSize="14">
                    <RichTextBox.Resources>
                        <Style TargetType="{x:Type Paragraph}">
                            <Setter Property="Margin" Value="0,5,0,5"/>
                        </Style>
                    </RichTextBox.Resources>
                </RichTextBox>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="5" Background="#16213E" CornerRadius="10" Margin="5" Padding="10" BorderBrush="#0F3460" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtUserInput" 
                         Grid.Column="0"
                         Height="45"
                         VerticalContentAlignment="Center"
                         Background="#0F3460"
                         Foreground="#FFFFFF"
                         BorderBrush="#00FFAA"
                         BorderThickness="1"
                         FontSize="14"
                         KeyDown="TxtUserInput_KeyDown"/>

                <Button x:Name="btnSend" 
                        Grid.Column="1"
                        Content="📤 Send" 
                        Width="80" 
                        Height="45"
                        Margin="5,0,0,0"
                        Background="#00FFAA"
                        Foreground="#1A1A2E"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="BtnSend_Click"/>

                <Button x:Name="btnVoice" 
                        Grid.Column="2"
                        Content="🔊 Voice" 
                        Width="80" 
                        Height="45"
                        Margin="5,0,0,0"
                        Background="#E94560"
                        Foreground="#FFFFFF"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="BtnVoice_Click"/>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="6" Background="#16213E" CornerRadius="10" Margin="5" Padding="8" BorderBrush="#0F3460" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="lblStatus" 
                           Text="✅ Ready" 
                           Foreground="#00FFAA" 
                           FontSize="12"/>
                <TextBlock Text=" | Ask me about: passwords • scams • privacy • phishing | Type 'exit' to quit" 
                           Foreground="#888888" 
                           FontSize="12"
                           Margin="20,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>